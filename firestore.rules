rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /player_secrets/{playerId} {
      allow read: if false;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // 公開ページ表示用に読み取りは許可する。
    // マスター画面はPINのみで運用するため、管理対象データの書き込みも許可する。
    match /players/{playerId} {
      allow read: if true;
      allow write: if true;
    }

    match /point_history/{historyId} {
      allow read: if false;
      allow write: if true;
    }

    match /sports_bets/{betId} {
      allow read: if true;
      allow write: if true;
    }

    match /speedstorm_records/{recordId} {
      allow read: if true;
      allow write: if true;
    }

    match /lotteries/{lotteryId} {
      allow read: if true;
      allow write: if true;
    }

    match /gift_codes/{giftCodeId} {
      allow read: if true;
      allow write: if true;
    }

    match /exercise_reports/{reportId} {
      allow read: if true;
      allow write: if true;
    }

    match /career_posts/{postId} {
      allow read: if true;
      allow write: if true;
    }

    match /manaba_credentials/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /manaba_assignments/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    match /territory_battle/{battleId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
